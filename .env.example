# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API key for your AI provider (Cerebras, Groq, Gemini, LiteLLM, etc.)
AI_API_KEY=your_ai_api_key_here

# Get these from https://console.upstash.com after creating a Redis database
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Optional: Tavily API key for web search — get one free at https://tavily.com (1,000 searches/month, no credit card)
# Without this key, web search is disabled.
# TAVILY_API_KEY=your_tavily_api_key_here

# Optional: random secret to verify webhook requests come from Telegram (recommended)
# Generate one with: openssl rand -hex 16
# Must also be passed as &secret_token= when registering the webhook
# WEBHOOK_SECRET=your_random_secret_here

# Optional: override the AI provider base URL (default: Cerebras)
# AI_BASE_URL=https://api.cerebras.ai/v1

# Optional: override the model name (default: llama3.1-8b)
# Other Cerebras options: gpt-oss-120b, qwen-3-235b-a22b-instruct-2507
# AI_MODEL=llama3.1-8b
